CREATE TABLE cart (
cartID INT GENERATED ALWAYS AS IDENTITY,
createdDate DATE NOT NULL,
createdTime TIME NOT NULL,
updatedDate DATE NOT NULL,
updatedTime TIME NOT NULL,
userID INT NOT NULL,
CONSTRAINT pk_cart PRIMARY KEY (cartID),
CONSTRAINT fk_cart_user FOREIGN KEY (userID) REFERENCES systemUser(userID),
CONSTRAINT chk_cart_dates_valid CHECK (updatedDate >= createdDate)
);

CREATE TABLE cartItem (
cartItemID INT GENERATED ALWAYS AS IDENTITY,
quantity INT NOT NULL,
remark VARCHAR(255),
size VARCHAR(100),
sweetness VARCHAR(100),
spiceLevel VARCHAR(100),
drinkOpt VARCHAR(100),
cartID INT NOT NULL,
menuItemID INT NOT NULL,
CONSTRAINT pk_cartItem PRIMARY KEY (cartItemID),
CONSTRAINT fk_cartItem_cart FOREIGN KEY (cartID) REFERENCES cart(cartID),
CONSTRAINT fk_cartItem_menuItem FOREIGN KEY (menuItemID) REFERENCES menuItem(menuItemID),
CONSTRAINT chk_cartItem_quantity_positive CHECK (quantity > 0)
);

CREATE TABLE order (
orderID INT GENERATED ALWAYS AS IDENTITY,
orderDate DATE NOT NULL,
orderTime TIME NOT NULL,
preparedTime TIME,
orderStatus VARCHAR(20) NOT NULL,
subtotalAmount DECIMAL(10,2) NOT NULL,
deductAmt DECIMAL(10,2),
deductRate DECIMAL(5,2),
totalAmount DECIMAL(10,2) NOT NULL,
tips DECIMAL(10,2),
pointEarned INT,
collectionMethod VARCHAR(100),
deliveryCompany VARCHAR(100),
deliveryMethod VARCHAR(100),
deliveryFee DECIMAL(10,2),
userID INT NOT NULL,
deliveryAddress INT NOT NULL,
CONSTRAINT pk_customerOrder PRIMARY KEY (orderID),
CONSTRAINT fk_customerOrder_user FOREIGN KEY (userID) REFERENCES systemUser(userID),
CONSTRAINT fk_customerAddress FOREIGN KEY (deliveryAddress) REFERENCES address(addressID),
CONSTRAINT chk_subtotal_nonnegative CHECK (subtotalAmount >= 0),
CONSTRAINT chk_deductAmt_nonnegative CHECK (deductAmt >= 0),
CONSTRAINT chk_deductRate_range CHECK (deductRate BETWEEN 0 AND 100),
CONSTRAINT chk_totalAmount_nonnegative CHECK (totalAmount >= 0),
CONSTRAINT chk_tips_nonnegative CHECK (tips >= 0),
CONSTRAINT chk_points_nonnegative CHECK (pointEarned >= 0),
CONSTRAINT chk_deliveryFee_nonnegative CHECK (deliveryFee >= 0),
CONSTRAINT chk_orderStatus_valid CHECK (orderStatus IN ('Pending','Preparing','Prepared','Completed','Cancelled'))
);


CREATE TABLE orderItem (
orderItemID INT GENERATED ALWAYS AS IDENTITY,
quantity INT NOT NULL,
remark VARCHAR(255),
size VARCHAR(20),
sweetness VARCHAR(20),
spiceLevel VARCHAR(20),
drinkOpt VARCHAR(50),
unitPrice DECIMAL(10,2) NOT NULL,
subtotal DECIMAL(10,2) NOT NULL,
discountPerItem DECIMAL(10,2),
totalDiscount DECIMAL(10,2),
total DECIMAL(10,2) NOT NULL,
orderID INT NOT NULL,
menuItemID INT NOT NULL,
CONSTRAINT pk_orderItem PRIMARY KEY (orderItemID),
CONSTRAINT fk_orderItem_order FOREIGN KEY (orderID) REFERENCES order(orderID),
CONSTRAINT fk_orderItem_menuItem FOREIGN KEY (menuItemID) REFERENCES menuItem(menuItemID),
CONSTRAINT chk_quantity_positive CHECK (quantity > 0),
CONSTRAINT chk_unitPrice_nonnegative CHECK (unitPrice >= 0),
CONSTRAINT chk_subtotal_nonnegative CHECK (subtotal >= 0),
CONSTRAINT chk_total_nonnegative CHECK (total >= 0)
CONSTRAINT chk_discountPerItem_nonnegative CHECK (discountPerItem >= 0),
CONSTRAINT chk_totalDiscount_nonnegative CHECK (totalDiscount >= 0),
CONSTRAINT chk_total_nonnegative CHECK (total >= 0),
CONSTRAINT chk_discount_not_exceed_subtotal CHECK (totalDiscount <= subtotal)
);

CREATE TABLE cancellation (
cancellationID INT GENERATED ALWAYS AS IDENTITY,
totalRefundAmount DECIMAL(10,2) NOT NULL,
cancelDate DATE NOT NULL,
cancelTime TIME NOT NULL,
orderID INT NOT NULL,
approvedBy INT,
status VARCHAR(20) NOT NULL,
CONSTRAINT pk_cancellation PRIMARY KEY (cancellationID),
CONSTRAINT fk_cancellation_order FOREIGN KEY (orderID) REFERENCES order(orderID),
CONSTRAINT fk_cancellation_admin FOREIGN KEY (approvedBy) REFERENCES systemAdmin(adminID),
CONSTRAINT chk_refund_nonnegativeCHECK (totalRefundAmount >= 0),
CONSTRAINT chk_cancellation_status CHECK (status IN ('Pending','Approved','Rejected'))
);

CREATE TABLE cancellationItem (
cancellationID INT NOT NULL,
orderItemID INT NOT NULL,
reason VARCHAR(255),
refundAmt DECIMAL(10,2) NOT NULL,
CONSTRAINT pk_cancellationItem PRIMARY KEY (cancellationID, orderItemID),
CONSTRAINT fk_cancellationItem_cancellation FOREIGN KEY (cancellationID) REFERENCES cancellation(cancellationID),
CONSTRAINT fk_cancellationItem_orderItem FOREIGN KEY (orderItemID) REFERENCES orderItem(orderItemID),
CONSTRAINT chk_refundAmt_nonnegative CHECK (refundAmt >= 0)
);

CREATE TABLE systemAdmin (
adminID INT GENERATED ALWAYS AS IDENTITY,
email VARCHAR(255) NOT NULL,
password VARCHAR(255) NOT NULL,
status BOOLEAN NOT NULL,
department VARCHAR(100) NOT NULL,
CONSTRAINT pk_systemAdmin PRIMARY KEY (adminID)
);

CREATE TABLE systemUser (
userID INT GENERATED ALWAYS AS IDENTITY,
name VARCHAR(100) NOT NULL,
email VARCHAR(255) NOT NULL,
password VARCHAR(255) NOT NULL,
status BOOLEAN NOT NULL,
gender VARCHAR(10) NOT NULL,
contactNo VARCHAR(15) NOT NULL,
DOB DATE NOT NULL,
memberStatus BOOLEAN NOT NULL,
memberPoint INT NOT NULL,
CONSTRAINT pk_systemUser PRIMARY KEY (userID),
CONSTRAINT chk_gender CHECK (gender IN ('Male', 'Female')),
CONSTRAINT chk_memberPoint_nonnegative CHECK (memberPoint >= 0),
CONSTRAINT chk_contactNo_format CHECK (contactNo ~ '^[0-9+-]+$')
);

CREATE TABLE address (
addressID INT GENERATED ALWAYS AS IDENTITY,
unit VARCHAR(50),
building VARCHAR(100),
street VARCHAR(200) NOT NULL,
city VARCHAR(100) NOT NULL,
postcode VARCHAR(10) NOT NULL,
state VARCHAR(100) NOT NULL,
country VARCHAR(100) NOT NULL,
userID INT,
CONSTRAINT pk_address PRIMARY KEY (addressID),
CONSTRAINT fk_address_user FOREIGN KEY (userID) REFERENCES systemUser(userID),
);

CREATE TABLE membershipType (
typeID INT GENERATED ALWAYS AS IDENTITY,
type VARCHAR(50) NOT NULL,
description VARCHAR(255) NOT NULL,
charges DECIMAL(10,2) NOT NULL,
coinRate DECIMAL(5,2) NOT NULL,
discountRate DECIMAL(5,2) NOT NULL,
birthCoin INT NOT NULL,
birthDiscount DECIMAL(5,2) NOT NULL,
deliveryPriority INT NOT NULL,
createdBy INT NOT NULL,
CONSTRAINT pk_membershipType PRIMARY KEY (typeID),
CONSTRAINT fk_membershipType_admin FOREIGN KEY (createdBy) REFERENCES systemAdmin(adminID),
CONSTRAINT chk_charges_positive CHECK (charges > 0),
CONSTRAINT chk_coinRate_positive CHECK (coinRate >= 0),
CONSTRAINT chk_discountRate_range CHECK (discountRate BETWEEN 0 AND 100),
CONSTRAINT chk_birthCoin_positive CHECK (birthCoin >= 0),
CONSTRAINT chk_birthDiscount_range CHECK (birthDiscount BETWEEN 0 AND 100),
CONSTRAINT chk_deliveryPriority_positive CHECK (deliveryPriority > 0)
);

CREATE TABLE subscription (
subscriptionID INT GENERATED ALWAYS AS IDENTITY,
date DATE NOT NULL,
expiration DATE NOT NULL,
status VARCHAR(20) NOT NULL,
userID INT NOT NULL,
typeID INT NOT NULL,
paymentID INT NOT NULL,
CONSTRAINT pk_subscription PRIMARY KEY (subscriptionID),
CONSTRAINT fk_subscription_user FOREIGN KEY (userID) REFERENCES systemUser(userID),
CONSTRAINT fk_subscription_membershipType FOREIGN KEY (typeID) REFERENCES membershipType(typeID),
CONSTRAINT fk_subscription_payment FOREIGN KEY (paymentID) REFERENCES payment(paymentID),
CONSTRAINT chk_subscription_dates CHECK (expiration >= date),
CONSTRAINT chk_subscription_status CHECK (status IN ('Active', 'Unactive'))
);

CREATE TABLE restaurant (
restaurantID INT GENERATED ALWAYS AS IDENTITY,
restaurantName VARCHAR(200) NOT NULL,
cuisineType VARCHAR(100) NOT NULL,
serviceStyle VARCHAR(100) NOT NULL,
openingHours TIME NOT NULL,
closingHours TIME NOT NULL,
serviceTax DECIMAL(5,2) NOT NULL,
halal BOOLEAN NOT NULL,
availability BOOLEAN NOT NULL,
addressID INT NOT NULL,
CONSTRAINT pk_restaurant PRIMARY KEY (restaurantID),
CONSTRAINT fk_restaurant_address FOREIGN KEY (addressID) REFERENCES address(addressID),
CONSTRAINT chk_restaurant_hours CHECK (closingHours > openingHours),
CONSTRAINT chk_serviceTax_range CHECK (serviceTax >= 0 AND serviceTax <= 100),
);

CREATE TABLE restaurantUser (
userID INT NOT NULL,
restaurantID INT NOT NULL,
accessLevel INT NOT NULL,
CONSTRAINT pk_restaurantUser PRIMARY KEY (userID, restaurantID),
CONSTRAINT fk_restaurantUser_user FOREIGN KEY (userID) REFERENCES systemUser(userID),
CONSTRAINT fk_restaurantUser_restaurant FOREIGN KEY (restaurantID) REFERENCES restaurant(restaurantID),
CONSTRAINT chk_accessLevel_range CHECK (accessLevel BETWEEN 1 AND 5)
);

CREATE TABLE driverTier(
  tierID INT GENERATED ALWAYS AS IDENTITY,
  comPerOrder DECIMAL (10,2)  NOT NULL,
  comPerFastOrder DECIMAL (10,2) NOT NULL,
  comPerKM DECIMAL (10,2)  NOT NULL,
  orderBonus DECIMAL (10,2)  NOT NULL,
  limitPerHour INT  NOT NULL,
  createdBy INT  NOT NULL, //adminID
  CONSTRAINT pk_driverTier PRIMARY KEY(tierID),
  CONSTRAINT fk_driverTier_createdBy FOREIGN KEY (createdBy) REFERENCES systemAdmin (adminID)
);

CREATE TABLE deliveryDriver(
  driverID INT GENERATED ALWAYS AS IDENTITY,
  name VARCHAR(255)  NOT NULL,
  email VARCHAR(255)  NOT NULL,
  password VARCHAR(255)  NOT NULL,
  status VARCHAR(255) NOT NULL,
  gender VARCHAR(255),
  contactNo VARCHAR(255)  NOT NULL,
  dob DATE,
  deliveryCompany VARCHAR(255) NOT NULL,
  point INT NOT NULL,
  basedIn VARCHAR(255) NOT NULL,
  currentLocation INT,  
  tierID INT NOT NULL,
  CONSTRAINT pk_deliveryDriver PRIMARY KEY(driverID),
  CONSTRAINT fk_deliveryDriver_tierID FOREIGN KEY(tierID) REFERENCES driverTier(tierID),
  CONSTRAINT fk_deliveryDriver_currentLocation FOREIGN KEY(currentLocation) REFERENCES address(addressID)
);

CREATE TABLE DELIVERYDRIVERKPI(
  KPIID INT GENERATED ALWAYS AS IDENTITY,
  POINT INT NOT NULL,
  ACCEPTORDER INT NOT NULL,
  DELAYEDORDER INT NOT NULL,
  AVGDELIVERYTIME DECIMAL(10,2) NOT NULL,
  AVGRATINGS DECIMAL(10,2) NOT NULL,
  REC0RDDATE DATE NOT NULL,
  DRIVERID INT NOT NULL,
  CONSTRAINT PK_DELIVERYDRIVERKPI PRTIMARY KEY(KPIID),
  CONSTRAINT FK_DELIVERYDRIVERKPI_DRIVERID FOREIGN KEY(DRIVERID) REFERENCES DELIVERYDRIVER(DRIVERID)
);

CREATE TABLE DELIVERYSCHEDULE(
  SCHEDULEID INT GENERATED ALWAYS AS IDENTITY,
  ORDERDATE DATE NOT NULL,
  EXPECTTIME TIME NOT NULL,
  DEPARTTIME TIME,
  REACHTIME TIME,
  COMMISSION DECIMAL(10,2) NOT NULL,
  DISTANCE DECIMAL(10,2) NOT NULL,
  STATUS VARCHAR(255) NOT NULL,
  POINT VARHCAR(255),
  DRIVERID INT,
  DEPARTADDRESS INT NOT NULL,
  DESTINATIONADDRESS INT NOT NULL,
  CONSTRAINT PK_DELIVERYSCHEDULE PRTIMARY KEY(SCHEDULEID),
  CONSTRAINT FK_DELIVERYSCHEDULE_DRIVERID FOREIGN KEY(DRIVERID) REFERENCES DELIVERYDRIVER(DRIVERID),
  CONSTRAINT FK_DELIVERYSCHEDULE_DEPARTADDRESS FOREIGN KEY(DEPARTADDRESS) REFERENCES ADDRESS(ADDRESSID),
  CONSTRAINT FK_DELIVERYSCHEDULE_DESTINATIONADDRESS FOREIGN KEY(DESTINATIONADDRESS) REFERENCES ADDRESS(ADDRESSID)
);

CREATE TABLE COMPENSATION(
  COMPENSATIONID INT GENERATED ALWAYS AS IDENTITY,
  COMPENSATION VARCHAR(255) NOT NULL,
  TOTALREFUNDAMT DECIMAL(10,2),
  ISSUEDDATE DATE NOT NULL;
  SCHEDULEID INT,
  ORDERID INT NOT NULL,
  VOUCHERID INT,
  CONSTRAINT PK_COMPENSATION PRTIMARY KEY(COMPENSATIONID),
  CONSTRAINT FK_COMPENSATION_SCHEDULEID FOREIGN KEY(SCHEDULEID) REFERENCES DELIVERYSCHEDULE(SCHEDULEID),
  CONSTRAINT FK_COMPENSATION_ORDERID FOREIGN KEY(ORDERID) REFERENCES ORDER(ORDERID),
  CONSTRAINT FK_COMPENSATION_VOUCHERID FOREIGN KEY(VOUCHERID) REFERENCES VOUCHER(VOUCHERID),
);

CREATE TABLE COMPENSATIONITEM(
  COMPENSATIONID INT,
  ORDERITEMID INT,
  QUANTITY INT NOT NULL,
  UNITPRICE DECIMAL(10,2) NOT NULL,
  REASON VARCHAR(255) NOT NULL,
  REFUNDAMT DECIMAL(10,2) NOT NULL,
  CONSTRAINT PK_COMPENSATIONITEM PRTIMARY KEY(COMPENSATIONID, ORDERITEMID),
  CONSTRAINT FK_COMPENSATIONITEM_COMPENSATIONID FOREIGN KEY(COMPENSATIONID) REFERENCES COMPENSATION(COMPENSATIONID),
  CONSTRAINT FK_COMPENSATIONITEM_ORDERITEMID FOREIGN KEY(ORDERITEMID) REFERENCES ORDERITEM(ORDERITEMID),
);

CREATE TABLE APPLICATION(
  APPLICATIONID INT GENERATED ALWAYS AS IDENTITY,
  TYPE VARCHAR(255) NOT NULL,
  STATUS VARCHAR(255) NOT NULL,
  APPLYBY INT NOT NULL,
  ISSUEDBY INT,
  RESTAURANTID INT NOT NULL,
  CONSTRAINT PK_APPLICATION PRIMARY KEY(APPLICATIONID),
  CONSTRAINT FK_APPLICATION_APPLYBY FOREIGN KEY(APPLYBY) REFERENCES SYSTEMUSER(USERID),
  CONSTRAINT FK_APPLICATION_ISSUEDBY FOREIGN KEY(ISSUEDBY) REFERENCES SYSTEMADMIN(ADMINID),
  CONSTRAINT FK_APPLICATION_RESTAURANTID FOREIGN KEY(RESTAURANTID) REFERENCES RESTAURANT(RESTAURANTID)
);

CREATE TABLE RATING (
  RATINGSID INT GENERATED ALWAYS AS IDENTITY,
  LEVEL INT NOT NULL,
  REVIEW VARCHAR(500),
  CREATEDBY INT NOT NULL,
  ORDERID INT,
  SCHEDULEID INT,
  CONSTRAINT PK_RATING PRIMARY KEY (RATINGSID),
  CONSTRAINT FK_RATING_CREATEDBY FOREIGN KEY (CREATEDBY) REFERENCES SYSTEMUSER(USERID),
  CONSTRAINT FK_RATING_ORDERID FOREIGN KEY (ORDERID) REFERENCES ORDER(ORDERID),
  CONSTRAINT FK_RATING_SCHEDULEID FOREIGN KEY (SCHEDULEID) REFERENCES DELIVERYSCHEDULE(SCHEDULEID),
  CONSTRAINT CHK_RATING_LEVEL CHECK (LEVEL >= 1 AND LEVEL <= 5)
);

CREATE TABLE PAYMENT (
  PAYMENTID INT GENERATED ALWAYS AS IDENTITY,
  PAYMENTDATE DATE NOT NULL,
  PAYMENTTIME TIME NOT NULL,
  TRANSACTIONFEE DECIMAL(10,2),
  TOTALAMOUNT DECIMAL(10,2) NOT NULL,
  PAYMENTMETHOD VARCHAR(100) NOT NULL,
  PAYMENTSTATUS VARCHAR(100) NOT NULL,
  ORDERID INT,
  USERID INT NOT NULL,
  CONSTRAINT PK_PAYMENT PRIMARY KEY (PAYMENTID),
  CONSTRAINT FK_PAYMENT_ORDERID FOREIGN KEY (ORDERID) REFERENCES ORDER(ORDERID),
  CONSTRAINT FK_PAYMENT_USERID FOREIGN KEY (USERID) REFERENCES SYSTEMUSER(USERID)
);

CREATE TABLE MENUITEM (
  MENUITEMID INT GENERATED ALWAYS AS IDENTITY,
  NAME VARCHAR(255) NOT NULL,
  PRICE DECIMAL(10,2) NOT NULL,
  SERVINGTIME INT,
  CALORIES INT,
  SIZE BOOLEAN,
  SWEETNESS BOOLEAN,
  SPICELEVEL BOOLEAN,
  DRINKOPT BOOLEAN,
  TYPEOFMEAT VARCHAR(100),
  VEGANFRIENDLY BOOLEAN,
  DISCOUNT DECIMAL(5,2),
  REMARK VARCHAR(500),
  CONSTRAINT PK_MENUITEM PRIMARY KEY (MENUITEMID)
);

CREATE TABLE MULTIMENUITEM (
  MENUID INT NOT NULL,
  MENUITEMID INT NOT NULL,
  CONSTRAINT PK_MULTIMENUITEM PRIMARY KEY (MENUID, MENUITEMID),
  CONSTRAINT FK_MULTIMENUITEM_MENUID FOREIGN KEY (MENUID) REFERENCES MENU(MENUID),
  CONSTRAINT FK_MULTIMENUITEM_MENUITEMID FOREIGN KEY (MENUITEMID) REFERENCES MENUITEM(MENUITEMID)
);

CREATE TABLE MENU (
  MENUID INT GENERATED ALWAYS AS IDENTITY,
  TYPE VARCHAR(100) NOT NULL,
  SERVINGSTART TIME NOT NULL,
  SERVINGEND TIME NOT NULL,
  AVAILABILITY BOOLEAN NOT NULL,
  RESTAURANTID INT NOT NULL,
  CONSTRAINT PK_MENU PRIMARY KEY (MENUID),
  CONSTRAINT FK_MENU_RESTAURANTID FOREIGN KEY (RESTAURANTID) REFERENCES RESTAURANT(RESTAURANTID),
  CONSTRAINT CHK_MENU_TIMES CHECK (SERVINGEND > SERVINGSTART)
);

CREATE TABLE campaign(
campaignID INT GENERATED ALWAYS AS IDENTITY,
name VARCHAR(100) NOT NULL,
desc VARCHAR(100) NOT NULL,
type VARCHAR(30),
startDate DATE NOT NULL,
validPeriod INT NOT NULL,
createdBy INT NOT NULL,
CONSTRAINT pk_campaign PRIMARY KEY (campaignID),
CONSTRAINT fk_campaign_admin FOREIGN KEY (createdBy) REFERENCES systemAdmin(adminID),
CONSTRAINT chk_type_valid CHECK (type IN ('voucher','membership point earning','cashback')),
CONSTRAINT chk_validPeriod_nonnegative CHECK (validPeriod > 0)
)

CREATE TABLE participatedRestaurant(
campaignID INT NOT NULL,
restaurantID INT NOT NULL,
participateDate DATE NOT NULL,
CONSTRAINT pk_participatedRestaurant PRIMARY KEY (campaignID, restaurantID),
CONSTRAINT fk_participatedRestaurant_restaurant FOREIGN KEY (restaurantID) REFERENCES restaurant(restaurantID),
CONSTRAINT fk_participatedRestaurant_campaign FOREIGN KEY (campaignID) REFERENCES campaign(campaignID)
)

CREATE TABLE voucher(
voucherID INT GENERATED ALWAYS AS IDENTITY,
name VARCHAR(100) NOT NULL,
desc VARCHAR(100) NOT NULL,
type VARCHAR(30) NOT NULL,
obtainMethod VARCHAR(30) NOT NULL,
creationDate DATE NOT NULL,
validPeriod INT NOT NULL,
minSpendAmt DOUBLE,
deductAmt DOUBLE,
deductRate DOUBLE,
totalRedemptionCount INT NOT NULL,
maxRedemption INT, 
status BOOLEAN NOT NULL,
createdBy INT NOT NULL,
CONSTRAINT pk_voucher PRIMARY KEY (voucherID),
CONSTRAINT fk_voucher_admin FOREIGN KEY (createdBy) REFERENCES systemAdmin(adminID),
CONSTRAINT chk_type_valid CHECK (type IN ('Discount by rate','Cash Rebate','Free delivery')),
CONSTRAINT chk_obtainMethod_valid CHECK (obtainMethod IN ('campaign','Compensation with Refund')),
CONSTRAINT chk_validPeriod_nonnegative CHECK (validPeriod > 0)
CONSTRAINT chk_deductRate_nonnegative_and_one CHECK (validPeriod > 0 AND validPeriod <1)
CONSTRAINT chk_totalRedemptionCount_nonnegative CHECK (totalRedemptionCount > 0)
)

CREATE TABLE campaignVoucher(
campaignID INT NOT NULL,
voucherID INT NOT NULL,
CONSTRAINT pk_campaignVoucher PRIMARY KEY (campaignID, voucherID),
CONSTRAINT pk_campaignVoucher_campaign FOREIGN KEY (campaignID) REFERENCES campaign(campaignID),
CONSTRAINT pk_campaignVoucher_voucher FOREIGN KEY (voucherID) REFERENCES voucher(voucherID)
)

CREATE TABLE voucherUser(
serialCode VARCHAR(19) NOT NULL,
status varchar(30) NOT NULL,
voucherID INT NOT NULL,
userID INT NOT NULL,
appliedOn INT,
CONSTRAINT pk_voucherUser PRIMARY KEY (serialCode),
CONSTRAINT pk_voucherUSer_voucher FOREIGN KEY (voucherID) REFERENCES voucher(voucherID),
CONSTRAINT pk_voucherUSer_user FOREIGN KEY (userID) REFERENCES systemUSer(userID),
CONSTRAINT pk_voucherUSer_order FOREIGN KEY (appliedOn) REFERENCES order(orderID),
CONSTRAINT chk_status_valid CHECK (status IN ('redeemed','Unredeemed'))
)


