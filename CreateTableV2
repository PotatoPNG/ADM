-- Trigger to auto-increment ID
CREATE OR REPLACE TRIGGER systemAdmin_trg
BEFORE INSERT ON systemAdmin
FOR EACH ROW
BEGIN
  :NEW.adminID := systemAdmin_seq.NEXTVAL;
END;
/
CREATE OR REPLACE TRIGGER systemUser_trg
BEFORE INSERT ON systemUser
FOR EACH ROW
BEGIN
  :NEW.userID := systemUser_seq.NEXTVAL;
END;
/
CREATE OR REPLACE TRIGGER address_trg
BEFORE INSERT ON address
FOR EACH ROW
BEGIN
  :NEW.addressID := address_seq.NEXTVAL;
END;
/
