-- Sequence
CREATE SEQUENCE systemAdmin_seq START WITH 1 INCREMENT BY 1;
CREATE SEQUENCE systemUser_seq START WITH 1 INCREMENT BY 1;
CREATE SEQUENCE address_seq START WITH 1 INCREMENT BY 1;
CREATE SEQUENCE cart_seq START WITH 1 INCREMENT BY 1;
CREATE SEQUENCE cartItem_seq START WITH 1 INCREMENT BY 1;
CREATE SEQUENCE orders_seq START WITH 1 INCREMENT BY 1;
CREATE SEQUENCE orderItem_seq START WITH 1 INCREMENT BY 1;
CREATE SEQUENCE cancellation_seq START WITH 1 INCREMENT BY 1;
CREATE SEQUENCE cancellationItem_seq START WITH 1 INCREMENT BY 1;

-- Table 
CREATE TABLE systemAdmin (
  adminID NUMBER PRIMARY KEY,
  email VARCHAR2(255) NOT NULL,
  password VARCHAR2(255) NOT NULL,
  status NUMBER(1) NOT NULL,
  department VARCHAR2(100) NOT NULL
);
CREATE TABLE systemUser (
  userID NUMBER PRIMARY KEY,
  name VARCHAR2(100) NOT NULL,
  email VARCHAR2(255) NOT NULL,
  password VARCHAR2(255) NOT NULL,
  status NUMBER(1) NOT NULL,
  gender VARCHAR2(10) NOT NULL,
  contactNo VARCHAR2(15) NOT NULL,
  DOB DATE NOT NULL,
  memberStatus NUMBER(1) NOT NULL,
  memberPoint NUMBER NOT NULL,
  CONSTRAINT chk_gender CHECK (gender IN ('Male','Female')),
  CONSTRAINT chk_memberPoint_nonnegative CHECK (memberPoint >= 0)
);
CREATE TABLE address (
  addressID NUMBER PRIMARY KEY,
  unit VARCHAR2(50),
  building VARCHAR2(100),
  street VARCHAR2(200) NOT NULL,
  city VARCHAR2(100) NOT NULL,
  postcode VARCHAR2(10) NOT NULL,
  state VARCHAR2(100) NOT NULL,
  country VARCHAR2(100) NOT NULL,
  userID NUMBER,
  CONSTRAINT fk_address_user FOREIGN KEY (userID) REFERENCES systemUser(userID)
);

